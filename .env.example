# ESPHome Device Builder dashboard URL (REST + WebSocket are derived from this).
# Point this at your own dashboard.
ESPHOME_DASHBOARD_URL=http://esphome.local:6052

# Behind a reverse proxy (HTTPS / wss is derived automatically):
# ESPHOME_DASHBOARD_URL=https://esphome.example.com

# Optional Basic Auth — only needed if the dashboard reports requires_auth=true.
# ESPHOME_DASHBOARD_USERNAME=
# ESPHOME_DASHBOARD_PASSWORD=

# Optional log level (DEBUG, INFO, WARNING, ERROR).
# LOG_LEVEL=INFO
